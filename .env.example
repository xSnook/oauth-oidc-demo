# ---------- MySQL container (local only) ----------
MYSQL_ROOT_PASSWORD=devroot
MYSQL_DATABASE=appdb
MYSQL_USER=appuser
MYSQL_PASSWORD=apppass
MYSQL_HOST_PORT=3306
REDIS_HOST_PORT=6379

# ---------- Backend ----------
APP_ENV=local
DATABASE_URL=mysql+pymysql://appuser:apppass@127.0.0.1:3306/appdb?charset=utf8mb4
REDIS_URL=redis://redis:6379/0
DB_REQUIRE_TLS=false
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_JWT_SECRET=
SESSION_TTL_HOURS=8
COOKIE_SECURE=false
GOOGLE_CLIENT_ID=
AZURE_CLIENT_ID=
AZURE_ADMIN_TENANT_ID=
ADMIN_EMAILS=you@example.com
LOG_LEVEL=INFO
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FAIL_OPEN=true
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_LOGOUT_PER_MINUTE=30
RATE_LIMIT_API_PER_MINUTE=120
RATE_LIMIT_ADMIN_WRITE_PER_MINUTE=30
